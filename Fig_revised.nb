Cell[BoxData[
 RowBox[{" ", 
  RowBox[{
   RowBox[{
    RowBox[{"\[Tau]", "[", "t_", "]"}], ":=", 
    RowBox[{"Mod", "[", 
     RowBox[{"t", ",", "1"}], "]"}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"invPrincipal", "[", "\[Tau]_", "]"}], ":=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"\[Tau]", "+", "Pi"}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{"2", " ", "Pi"}], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"ClearAll", "[", "vonMisesPDF", "]"}], "\n", 
   RowBox[{
    RowBox[{"vonMisesPDF", "[", 
     RowBox[{"x_", ",", "\[Mu]_", ",", "\[Kappa]_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "/", 
       RowBox[{"(", 
        RowBox[{"BesselI", "[", 
         RowBox[{"0", ",", "\[Kappa]"}], "]"}], ")"}]}], ")"}], "*", 
     RowBox[{"Exp", "[", 
      RowBox[{"\[Kappa]", " ", 
       RowBox[{"Cos", "[", 
        RowBox[{"2", "\[Pi]", 
         RowBox[{"(", 
          RowBox[{"x", "-", "\[Mu]"}], ")"}]}], "]"}]}], "]"}]}]}], 
   "\[IndentingNewLine]", 
   RowBox[{"d\[Phi]", "=", 
    RowBox[{
     RowBox[{"D", "[", " ", 
      RowBox[{
       RowBox[{"vonMisesPDF", "[", 
        RowBox[{
         RowBox[{"\[Tau]", "[", "t", "]"}], ",", "\[Theta]", ",", "k"}], 
        "]"}], ",", "\[Theta]"}], "]"}], "//", "Simplify"}]}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"sub\[Beta]", "=", 
     RowBox[{"{", 
      RowBox[{"\[Beta]", "->", 
       RowBox[{"\[Beta]0", "*", 
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{"\[Delta]", "*", 
           RowBox[{"Cos", "[", 
            RowBox[{"2", "\[Pi]", 
             RowBox[{"(", 
              RowBox[{"t", "-", 
               RowBox[{"1", "/", "2"}]}], ")"}]}], "]"}]}]}], ")"}]}]}], 
      "}"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"sub\[Phi]", "=", 
     RowBox[{"{", 
      RowBox[{"\[Phi]", "->", 
       RowBox[{"vonMisesPDF", "[", 
        RowBox[{
         RowBox[{"\[Tau]", "[", "t", "]"}], ",", "\[Theta]", ",", "k"}], 
        "]"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Rho]", "[", "z_", "]"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"\[Beta]", "*", "s", "*", 
        RowBox[{"vonMisesPDF", "[", 
         RowBox[{
          RowBox[{"\[Tau]", "[", "t", "]"}], ",", "\[Theta]", ",", "k"}], 
         "]"}]}], "-", 
       RowBox[{"(", 
        RowBox[{"d", "+", "\[Gamma]", "+", "\[Alpha]"}], ")"}]}], "/.", 
      "sub\[Beta]"}], "/.", 
     RowBox[{"\[Theta]", "->", "z"}]}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ds", "=", 
     RowBox[{
      RowBox[{"d", "*", 
       RowBox[{"(", 
        RowBox[{"s", "+", "j", "+", "r"}], ")"}]}], "-", 
      RowBox[{"d", "*", "s"}], "+", 
      RowBox[{"c", "*", "r"}], "-", 
      RowBox[{"\[Beta]", "*", "s", "*", "\[Phi]", "*", "j"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"dj", "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"\[Beta]", "*", "s", "*", "\[Phi]"}], "-", 
        RowBox[{"(", 
         RowBox[{"d", "+", "\[Gamma]", "+", "\[Alpha]"}], ")"}]}], ")"}], "*",
       "j"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"dr", "=", 
     RowBox[{
      RowBox[{"\[Gamma]", "*", "j"}], "-", 
      RowBox[{"d", "*", "r"}], "-", 
      RowBox[{"c", "*", "r"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"subvarfvz", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"s", "->", 
        RowBox[{"s", "[", "t", "]"}]}], ",", 
       RowBox[{"j", "->", 
        RowBox[{"j", "[", "t", "]"}]}], ",", 
       RowBox[{"r", "->", 
        RowBox[{"r", "[", "t", "]"}]}]}], "}"}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.967794704105383*^9, 3.967794733497244*^9}, {
