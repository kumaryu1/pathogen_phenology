Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"vonMisesPDF", "[", 
   RowBox[{"x_", ",", "\[Mu]_", ",", "\[Kappa]_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"1", "/", 
     RowBox[{"(", 
      RowBox[{"BesselI", "[", 
       RowBox[{"0", ",", "\[Kappa]"}], "]"}], ")"}]}], ")"}], "*", 
   RowBox[{"Exp", "[", 
    RowBox[{"\[Kappa]", " ", 
     RowBox[{"Cos", "[", 
      RowBox[{"2", "\[Pi]", 
       RowBox[{"(", 
        RowBox[{"x", "-", "\[Mu]"}], ")"}]}], "]"}]}], 
    "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sub\[Beta]", "=", 
   RowBox[{"{", 
    RowBox[{"\[Beta]", "->", 
     RowBox[{"\[Beta]0", "*", 
      RowBox[{"(", 
       RowBox[{"1", "+", 
        RowBox[{"\[Delta]", "*", 
         RowBox[{"Cos", "[", 
          RowBox[{"2", "\[Pi]", 
           RowBox[{"(", 
            RowBox[{"t", "-", 
             RowBox[{"1", "/", "2"}]}], ")"}]}], "]"}]}]}], ")"}]}]}], 
    "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sub\[Phi]", "=", 
   RowBox[{"{", 
    RowBox[{"\[Phi]", "->", 
     RowBox[{"vonMisesPDF", "[", 
      RowBox[{"t", ",", "\[Theta]", ",", "k"}], "]"}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{" ", 
  RowBox[{
   RowBox[{"Funcmax", "[", 
    RowBox[{"\[Beta]0v_", ",", "\[Delta]v_"}], "]"}], ":=", " ", 
   RowBox[{"NIntegrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"\[Beta]", " ", "\[Phi]"}], "-", 
            RowBox[{"(", 
             RowBox[{"d", "+", "\[Gamma]"}], ")"}]}], "/.", "sub\[Beta]"}], "/.",
           "sub\[Phi]"}], "/.", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"d", "->", "0.1"}], ",", 
           RowBox[{"\[Gamma]", "->", "1"}], ",", 
           RowBox[{"\[Alpha]", "->", "0"}], ",", 
           RowBox[{"c", "->", "0.5"}], ",", 
           RowBox[{"k", "->", "1"}], ",", 
           RowBox[{"vm", "->", "0."}]}], "}"}]}], "/.", 
        RowBox[{"\[Theta]", "->", 
         RowBox[{"1", "/", "2"}]}]}], "/.", 
       RowBox[{"\[Beta]0", "->", "\[Beta]0v"}]}], "/.", 
      RowBox[{"\[Delta]", "->", "\[Delta]v"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "1"}], "}"}]}], 
    "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Funcmin", "[", 
   RowBox[{"\[Beta]0v_", ",", "\[Delta]v_"}], "]"}], ":=", " ", 
  RowBox[{"NIntegrate", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"\[Beta]", " ", "\[Phi]"}], "-", 
           RowBox[{"(", 
            RowBox[{"d", "+", "\[Gamma]"}], ")"}]}], "/.", "sub\[Beta]"}], "/.",
          "sub\[Phi]"}], "/.", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"d", "->", "0.1"}], ",", 
          RowBox[{"\[Gamma]", "->", "1"}], ",", 
          RowBox[{"\[Alpha]", "->", "0"}], ",", 
          RowBox[{"c", "->", "0.5"}], ",", 
          RowBox[{"k", "->", "1"}], ",", 
          RowBox[{"vm", "->", "0."}]}], "}"}]}], "/.", 
       RowBox[{"\[Theta]", "->", "0"}]}], "/.", 
      RowBox[{"\[Beta]0", "->", "\[Beta]0v"}]}], "/.", 
     RowBox[{"\[Delta]", "->", "\[Delta]v"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "1"}], "}"}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ContourPlot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"Funcmax", "[", 
      RowBox[{"\[Beta]0", ",", "\[Delta]"}], "]"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"\[Beta]0", ",", "0", ",", "2.2"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"\[Delta]", ",", "0", ",", "1"}], "}"}], ",", 
    RowBox[{"Contours", "->", 
     RowBox[{"{", "0", "}"}]}], ",", 
    RowBox[{"ContourShading", "->", 
     RowBox[{"{", 
      RowBox[{"Black", ",", "None"}], "}"}]}]}], "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ContourPlot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"Funcmin", "[", 
      RowBox[{"\[Beta]0", ",", "\[Delta]"}], "]"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"\[Beta]0", ",", "0", ",", "2.2"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"\[Delta]", ",", "0", ",", "1"}], "}"}], ",", 
    RowBox[{"Contours", "->", 
     RowBox[{"{", "0", "}"}]}], ",", 
    RowBox[{"ContourShading", "->", 
     RowBox[{"{", 
      RowBox[{"Gray", ",", "None"}], "}"}]}]}], "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"P1C", "=", 
  RowBox[{"Show", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"%", ",", "%%"}], "}"}], ",", 
    RowBox[{"FrameStyle", "->", 
     RowBox[{"Directive", "[", 
      RowBox[{"Black", ",", "12"}], "]"}]}], ",", 
    RowBox[{"ImageSize", "->", 
     RowBox[{"{", 
      RowBox[{"Automatic", ",", "400"}], "}"}]}], ",", 
    RowBox[{"FrameLabel", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Style", "[", 
        RowBox[{
        "\"\<Average transmission rate, \!\(\*SubscriptBox[\(\[Beta]\), \
\(0\)]\)\>\"", ",", "22"}], "]"}], ",", 
       RowBox[{"Style", "[", 
        RowBox[{
        "\"\<Degree of environmental fluctuation, \[Delta]\>\"", ",", "22"}], 
        "]"}]}], "}"}]}], ",", 
    RowBox[{"Epilog", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Text", "[", 
        RowBox[{
         RowBox[{"Style", "[", 
          RowBox[{
          "\"\<max \!\(\*SubscriptBox[\(R\), \(0\)]\) < 1\>\"", ",", "White", 
           ",", "22"}], "]"}], ",", 
         RowBox[{"Scaled", "[", 
          RowBox[{"{", 
           RowBox[{"0.2", ",", "0.2"}], "}"}], "]"}]}], "]"}], ",", 
       RowBox[{"Text", "[", 
        RowBox[{
         RowBox[{"Style", "[", 
          RowBox[{
          "\"\<max \!\(\*SubscriptBox[\(R\), \(0\)]\) > 1\\n&\\n min \
\!\(\*SubscriptBox[\(R\), \(0\)]\) < 1\>\"", ",", "Black", ",", "22"}], "]"}],
          ",", 
         RowBox[{"Scaled", "[", 
          RowBox[{"{", 
           RowBox[{"0.55", ",", "0.8"}], "}"}], "]"}]}], "]"}], ",", 
       RowBox[{"Text", "[", 
        RowBox[{
         RowBox[{"Style", "[", 
          RowBox[{
          "\"\<min \!\(\*SubscriptBox[\(R\), \(0\)]\) > 1\>\"", ",", "Black", 
           ",", "22"}], "]"}], ",", 
         RowBox[{"Scaled", "[", 
          RowBox[{"{", 
           RowBox[{"0.8", ",", "0.2"}], "}"}], "]"}]}], "]"}]}], "}"}]}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"P1C", "=", 
   RowBox[{"Rasterize", "[", 
    RowBox[{"P1C", ",", "\"\<Image\>\"", ",", 
     RowBox[{"ImageResolution", "->", "300"}], ",", 
     RowBox[{"ImageSize", "->", "500"}]}], "]"}]}], ";"}]}], "Input",
