Cell[BoxData[
 RowBox[{"    ", 
  RowBox[{"(*", "\:533a\:9593", "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"t1", "=", "999"}], ";", 
    RowBox[{"t2", "=", "1000"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"\[Theta]v", "=", 
    RowBox[{"1", "/", "4"}]}], "\[IndentingNewLine]", 
   RowBox[{"\[Theta]v2", "=", 
    RowBox[{"3", "/", "4"}]}], "\[IndentingNewLine]", 
   RowBox[{"\[Theta]v3", "=", 
    RowBox[{"1", "/", "2"}]}], "\[IndentingNewLine]", "  ", 
   RowBox[{"par", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"d", "->", "0.1"}], ",", 
      RowBox[{"\[Gamma]", "->", "1"}], ",", 
      RowBox[{"\[Alpha]", "->", "0"}], ",", 
      RowBox[{"c", "->", "0.5"}], ",", 
      RowBox[{"k", "->", "1"}], ",", 
      RowBox[{"\[Beta]0", "->", "5"}], ",", 
      RowBox[{"\[Delta]", "->", "1"}], ",", 
      RowBox[{"vm", "->", "0."}]}], "}"}]}], "\[IndentingNewLine]", 
   RowBox[{"initfvz", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"s", "[", "0", "]"}], "==", 
       RowBox[{"1", "-", "0.01"}]}], ",", 
      RowBox[{
       RowBox[{"j", "[", "0", "]"}], "==", "0.01"}], ",", 
      RowBox[{
       RowBox[{"r", "[", "0", "]"}], "==", "0"}]}], "}"}]}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"dynfvz", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"s", "'"}], "[", "t", "]"}], "==", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"ds", "/.", "sub\[Beta]"}], "/.", "sub\[Phi]"}], "/.", 
          "subvarfvz"}], ")"}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"j", "'"}], "[", "t", "]"}], "==", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"dj", "/.", "sub\[Beta]"}], "/.", "sub\[Phi]"}], "/.", 
          "subvarfvz"}], ")"}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"r", "'"}], "[", "t", "]"}], "==", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"dr", "/.", "sub\[Beta]"}], "/.", "sub\[Phi]"}], "/.", 
          "subvarfvz"}], ")"}]}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"sysfvz", "=", 
     RowBox[{"Join", "[", 
      RowBox[{"dynfvz", ",", "initfvz"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"tend", "=", "1000"}], "\[IndentingNewLine]", 
   RowBox[{"sol", "=", 
    RowBox[{"NDSolve", "[", 
     RowBox[{
      RowBox[{"Evaluate", "[", 
