Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{" ", 
  RowBox[{
   RowBox[{
    RowBox[{"matrixoligomorph", "=", "\[IndentingNewLine]", 
     RowBox[{"Rest", "@", 
      RowBox[{"Import", "[", 
       RowBox[{
       "\"\<output/oligo_data/traj_for_figure_M2_fast_large_var_detailed2_\
online_old_d=0.2_morph.csv\>\"", ",", "\"\<Table\>\""}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"matrixoligomoved", "=", "\[IndentingNewLine]", 
     RowBox[{"Rest", "@", 
      RowBox[{"Import", "[", 
       RowBox[{
       "\"\<output/oligo_data/traj_for_figure_M2_fast_large_var_detailed2_\
online_old_d=0.2_moved.csv\>\"", ",", "\"\<Table\>\""}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "   ", 
   RowBox[{"tol", "=", "0.005"}], 
   RowBox[{"(*", 
    RowBox[{"0.005", ";"}], "  ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"TV", "=", "3"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"assocmorph", "=", 
     RowBox[{"Association", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"#", "[", 
          RowBox[{"[", 
           RowBox[{"1", ";;", "2"}], "]"}], "]"}], "->", 
         RowBox[{"#", "[", 
          RowBox[{"[", "3", "]"}], "]"}]}], "&"}], "/@", "matrixoligomorph"}],
       "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"assoctrait", "=", 
     RowBox[{"Association", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"#", "[", 
          RowBox[{"[", 
           RowBox[{"1", ";;", "2"}], "]"}], "]"}], "->", 
         RowBox[{"#", "[", 
          RowBox[{"[", "3", "]"}], "]"}]}], "&"}], "/@", "matrixoligomoved"}],
       "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"commonXY", "=", 
     RowBox[{"Intersection", "[", 
      RowBox[{
       RowBox[{"Keys", "[", "assocmorph", "]"}], ",", 
       RowBox[{"Keys", "[", "assoctrait", "]"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"conditionphase", "[", 
     RowBox[{"z1_", ",", "z2_"}], "]"}], ":=", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"1", "-", "tol"}], "<", 
       RowBox[{"assocmorph", "[", 
        RowBox[{"{", 
         RowBox[{"z1", ",", "z2"}], "}"}], "]"}], "<", 
       RowBox[{"1", "+", "tol"}]}], ",", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Abs", "[", 
          RowBox[{"assoctrait", "[", 
           RowBox[{"{", 
            RowBox[{"z1", ",", "z2"}], "}"}], "]"}], "]"}], ">", "TV"}], ",", 
        "1", ",", "2"}], "]"}], ",", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"2", "-", "tol"}], "<", 
         RowBox[{"assocmorph", "[", 
          RowBox[{"{", 
           RowBox[{"z1", ",", "z2"}], "}"}], "]"}], "<", 
         RowBox[{"2", "+", "tol"}]}], ",", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Abs", "[", 
            RowBox[{"assoctrait", "[", 
             RowBox[{"{", 
              RowBox[{"z1", ",", "z2"}], "}"}], "]"}], "]"}], ">", "TV"}], 
          ",", "3", ",", "4"}], "]"}], ",", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Abs", "[", 
            RowBox[{"assoctrait", "[", 
             RowBox[{"{", 
              RowBox[{"z1", ",", "z2"}], "}"}], "]"}], "]"}], ">", "TV"}], 
          ",", "5", ",", "6"}], "]"}]}], "]"}]}], "]"}]}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"resultList", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"#1", ",", "#2", ",", 
         RowBox[{"conditionphase", "[", 
          RowBox[{"#1", ",", "#2"}], "]"}]}], "}"}], "&"}], "@@@", 
      "commonXY"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   " \:3000 ", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"A", ".", "Blue"}], "\[Times]", "Yellow"}], "*)"}], 
